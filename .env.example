OPENWEATHER_API_KEY=

# Optional: leave blank to use the airport coordinates from the weather notebook.
OPENWEATHER_LAT=
OPENWEATHER_LON=
OPENWEATHER_TIMEOUT_SECONDS=2

# Optional Netlify frontend override. Leave blank when using the netlify.toml /api proxy.
VITE_API_BASE_URL=https://your-django-backend.example.com
NETLIFY_SITE_URL=https://airportoptai.netlify.app/

# Render/Django production options.
SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://airportoptai.netlify.app/
CORS_ALLOWED_ORIGIN_REGEXES=^http://localhost:\d+$,^http://127\.0\.0\.1:\d+$,^https://[a-z0-9-]+\.netlify\.app$
CSRF_TRUSTED_ORIGINS=https://airportoptai.netlify.app/
DATABASE_URL=
